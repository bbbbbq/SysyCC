{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug SysyCC Minimal",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/SysyCC",
            "args": [
                "tests/minimal/minimal.sy"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Debug SysyCC Dump Parse",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/SysyCC",
            "args": [
                "--dump-tokens",
                "--dump-parse",
                "tests/minimal/minimal.sy"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Debug SysyCC Function Macro",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/SysyCC",
            "args": [
                "--dump-tokens",
                "--dump-parse",
                "tests/function_macro/function_macro.sy"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build"
        }
    ]
}
