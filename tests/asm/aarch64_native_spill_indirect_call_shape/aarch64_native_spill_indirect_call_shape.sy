int inc(int x) { return x + 1; }

int spill_indirect_call_shape(int (*fp)(int), int *p, int a, int b, int c, int d,
                              int e, int f) {
    int x0 = p[a];
    int x1 = p[b];
    int x2 = p[c];
    int x3 = p[d];
    int x4 = p[e];
    int x5 = p[f];
    return fp(x0 + x1 + x2 + x3) + x4 + x5;
}

int main() {
    int data[6] = {1, 2, 3, 4, 5, 6};
    return spill_indirect_call_shape(inc, data, 0, 1, 2, 3, 4, 5);
}
