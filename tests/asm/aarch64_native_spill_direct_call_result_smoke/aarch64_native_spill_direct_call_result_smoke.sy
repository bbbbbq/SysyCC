int inc(int x) { return x + 1; }

int heavy(int *p, int a, int b, int c, int d, int e, int f) {
    int x0 = p[a];
    int x1 = p[b];
    int x2 = p[c];
    int x3 = p[d];
    int x4 = p[e];
    int x5 = p[f];
    return x0 + x1 + x2 + inc(x3 + x4) + x5;
}

int main() {
    int values[6];
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    values[3] = 4;
    values[4] = 5;
    values[5] = 6;
    putint(heavy(values, 0, 1, 2, 3, 4, 5));
    return 0;
}
