int cmp_half_heavy(_Float16 *p, int a, int b, int c, int d, int e, int f) {
    _Float16 x0 = p[a];
    _Float16 x1 = p[b];
    _Float16 x2 = p[c];
    _Float16 x3 = p[d];
    _Float16 x4 = p[e];
    _Float16 x5 = p[f];

    _Float16 lhs = x0 + x1 + x2;
    _Float16 rhs = x3 + x4 + x5;
    return lhs < rhs;
}
