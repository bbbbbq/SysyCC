struct Big {
    long long a;
    long long b;
    long long c;
};

int sink_big(int p0, int p1, int p2, int p3, int p4, int p5, int p6, int p7,
             struct Big value) {
    return p0 + p1 + p2 + p3 + p4 + p5 + p6 + p7 + (int)value.c;
}

int call_big(struct Big value) {
    return sink_big(1, 2, 3, 4, 5, 6, 7, 8, value);
}
