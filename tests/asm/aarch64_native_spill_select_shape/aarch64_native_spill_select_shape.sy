int spill_select_heavy(long double a, long double b, int *p, int i0, int i1,
                       int i2, int i3, int i4, int i5, int i6) {
    int x0 = p[i0];
    int x1 = p[i1];
    int x2 = p[i2];
    int x3 = p[i3];
    int x4 = p[i4];
    int x5 = p[i5];
    int x6 = p[i6];
    int y0 = x0 + i0;
    int y1 = x1 + i1;
    int y2 = x2 + i2;
    int y3 = x3 + i3;
    int y4 = x4 + i4;
    int y5 = x5 + i5;
    int y6 = x6 + i6;
    int z0 = y0 + y3;
    int z1 = y1 + y4;
    int z2 = y2 + y5;
    int cmp = a < b;
    return cmp + y0 + y1 + y2 + y3 + y4 + y5 + y6 + z0 + z1 + z2;
}
