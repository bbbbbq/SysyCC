long double bump(long double value) {
    return value + (long double)1;
}

int main() {
    long double a;
    long double b;
    long double c;
    long double d;
    long double left;
    long double right;
    long double keep;

    a = (long double)getint();
    b = (long double)2;
    c = (long double)3;
    d = (long double)4;
    left = a + b;
    right = c + d;
    keep = left + right;
    putint((int)bump(keep));
    return 0;
}
