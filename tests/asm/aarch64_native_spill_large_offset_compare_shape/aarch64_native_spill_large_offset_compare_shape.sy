int cmp_big(int *p, int a, int b, int c, int d, int e, int f, int g) {
    int big[128];
    big[127] = a + b;

    int x0 = p[a] + big[127];
    int x1 = p[b] + big[127];
    int x2 = p[c] + big[127];
    int x3 = p[d] + big[127];
    int x4 = p[e] + big[127];
    int x5 = p[f] + big[127];
    int x6 = p[g] + big[127];

    return (x0 + x1 + x2) < (x3 + x4 + x5 + x6);
}
