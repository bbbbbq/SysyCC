double inc(double x) {
    return x + 1.0;
}

int main() {
    int ai;
    int bi;
    double da;
    double db;
    int keep_i;
    double keep_f;

    ai = getint();
    bi = getint();
    da = (double)getint();
    db = (double)getint();

    keep_i = ai + bi;
    keep_f = da + db;
    putint(keep_i + (int)(keep_f + inc(da)));
    return 0;
}
