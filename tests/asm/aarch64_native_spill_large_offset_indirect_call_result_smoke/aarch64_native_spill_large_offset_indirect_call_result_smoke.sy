int inc(int x) { return x + 1; }

int heavy_big_indirect(int (*fp)(int), int *p, int a, int b, int c, int d, int e,
                       int f) {
    int big[128];
    big[127] = a + b;

    int x0 = p[a] + big[127];
    int x1 = p[b] + big[127];
    int x2 = p[c] + big[127];
    int x3 = p[d] + big[127];
    int x4 = p[e] + big[127];
    int x5 = p[f] + big[127];

    return fp(x0 + x1 + x2 + x3) + x4 + x5;
}

int main() {
    int data[6];
    data[0] = 1;
    data[1] = 2;
    data[2] = 3;
    data[3] = 4;
    data[4] = 5;
    data[5] = 6;
    putint(heavy_big_indirect(inc, data, 0, 1, 2, 3, 4, 5));
    return 0;
}
