int main() {
    int i = 0;
    for (i = 0; i < 3; i = i + 1) {
        do {
            if (i == 1) {
                break;
            }
        } while (i < 2);

        switch (i) {
            case 0: {
                i = i + 1;
                break;
            }
            default: {
                i = i + 2;
            }
        }
    }
    return i;
}
