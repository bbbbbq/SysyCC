static struct UsedAtom {
    union {
        struct {
            enum {
                RR_REF,
                RR_TRACK
            } option;
            int refname;
        } remote_ref;
        struct {
            enum {
                C_BARE,
                C_BODY
            } option;
        } contents;
    } u;
} used_atom[1];

int main(void) {
    used_atom[0].u.remote_ref.option = RR_TRACK;
    return used_atom[0].u.remote_ref.option == RR_TRACK ? 0 : 1;
}
