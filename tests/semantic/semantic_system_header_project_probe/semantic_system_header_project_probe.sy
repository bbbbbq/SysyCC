#include "project_probe.h"

int project_probe_fill(struct ProjectProbeRecord *record, const char *src) {
    char local[16];
    void *buffer = malloc(sizeof(local));

    memcpy(local, src, sizeof(local));
    record->bytes = sizeof(local);
    record->signed_bytes = (ssize_t)record->bytes;
    record->offset = (off_t)record->signed_bytes;
    record->score = local[0] == 'o' ? INT_MAX : -1;
    record->mask = UINT64_MAX;

    errno = EINVAL;
    assert(record->signed_bytes >= 0);

    if (buffer != NULL) {
        free(buffer);
    }

    return isnan(0.0) ? 1 : (errno == EINVAL && record->score == INT_MAX ? 0 : 2);
}

int main(void) {
    struct ProjectProbeRecord record;
    return project_probe_fill(&record, "ok");
}
