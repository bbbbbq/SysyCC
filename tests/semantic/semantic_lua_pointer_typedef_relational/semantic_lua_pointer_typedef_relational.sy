typedef union StackValue {
    int value;
} StackValue;

typedef StackValue *StkId;

typedef union {
    StkId p;
    long offset;
} StkIdRel;

typedef struct lua_State {
    StkIdRel top;
} lua_State;

static int check_stack(lua_State *L, StkId o) {
    if (o >= L->top.p) return 1;
    if (L->top.p < o + 1) return 2;
    return 0;
}

int main(void) {
    return 0;
}
