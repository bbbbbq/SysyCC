struct item {
    char *string;
    void *util;
};

struct string_list {
    struct item *items;
    unsigned long nr;
    unsigned long alloc;
    unsigned int strdup_strings:1;
    int (*cmp)(const char *, const char *);
};

struct strbuf {
    unsigned long alloc;
    unsigned long len;
    char *buf;
};

extern char strbuf_slopbuf[];

static struct string_list output = { .strdup_strings = 1 };
static struct strbuf buf = { .buf = strbuf_slopbuf };
