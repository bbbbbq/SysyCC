struct option {
    int tag;
};

void *copy_array(void *dst, const void *src, unsigned long n,
                 unsigned long size);

int concat_options(struct option *ret, const struct option *a,
                   unsigned long a_len) {
    copy_array((ret), (a), (a_len),
               sizeof(*(ret)) +
                   (sizeof(char [1 - 2*!(__builtin_types_compatible_p(
                                      __typeof__(*((ret))),
                                      __typeof__(*((a)))))]) - 1));
    return 0;
}
