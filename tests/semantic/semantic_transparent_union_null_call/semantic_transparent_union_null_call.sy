struct sockaddr;
struct sockaddr_in;

typedef union {
    struct sockaddr *__sockaddr__;
    struct sockaddr_in *__sockaddr_in__;
} sockaddr_arg __attribute__((__transparent_union__));

int accept_like(int fd, sockaddr_arg addr, unsigned int *len);

int probe(int fd) {
    return accept_like(fd, (void *)0, (void *)0);
}
