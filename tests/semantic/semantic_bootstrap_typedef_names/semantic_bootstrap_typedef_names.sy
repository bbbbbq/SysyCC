typedef size_t my_size_t;
typedef ptrdiff_t my_ptrdiff_t;
typedef va_list my_va_list;
typedef wchar_t my_wchar_t;
typedef uint32_t my_u32_t;
typedef int32_t my_i32_t;
typedef uint64_t my_u64_t;
typedef intptr_t my_intptr_t;
typedef uintptr_t my_uintptr_t;

my_size_t next_size(my_size_t value) {
    return value + 1;
}

int main() {
    my_size_t count;
    my_ptrdiff_t diff;
    my_va_list args;
    my_wchar_t code;
    my_u32_t u32;
    my_i32_t i32;
    my_u64_t u64;
    my_intptr_t ip;
    my_uintptr_t up;

    count = 1;
    diff = 2;
    args = 0;
    code = 3;
    u32 = 4;
    i32 = 5;
    u64 = 6;
    ip = 7;
    up = 8;
    return (int)(count + diff + code + u32 + i32 + (int)u64 + (int)ip +
                 (int)up);
}
