unsigned int shift_unsigned(unsigned int value) {
    return value >> 1;
}

int shift_short(short value) {
    return value << 1;
}

long int bitwise_mixed(long int lhs, unsigned int rhs) {
    return (lhs & rhs) | (lhs ^ rhs);
}

int mod_small(short lhs, unsigned short rhs) {
    return lhs % rhs;
}

