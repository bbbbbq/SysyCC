// Test: ternary operator in const initializer
// Bug coverage: ConditionalExpr missing from evaluate_integer_expr()
// The constant evaluator must support ternary expressions for:
// - const int initializers
// - array dimensions
// - case labels
// - enum values

const int x = 1;
const int y = 2;
const int z = (x > y) ? x : y;

int get_z(void) {
    return z;
}

int main(void) {
    return z != 2;
}
