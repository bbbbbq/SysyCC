typedef unsigned char byte;

typedef union Value {
    void *gc;
    int i;
} Value;

typedef struct Cell {
    Value value;
    byte tag;
} Cell;

typedef struct {
    Cell *dummy;
    Cell follows_pointer;
} OffsetBoxAux;

typedef union {
    Cell *last;
    char padding[((unsigned long)(&(((OffsetBoxAux *)0)->follows_pointer)))];
} OffsetBox;

unsigned long size_probe(void) {
    return sizeof(Cell) + sizeof(OffsetBox);
}
