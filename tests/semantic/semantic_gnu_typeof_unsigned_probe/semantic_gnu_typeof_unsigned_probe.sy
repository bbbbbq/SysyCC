typedef unsigned long size_t;

#define BUILD_ASSERT_OR_ZERO(cond) (sizeof(char [1 - 2*!(cond)]) - 1)
#define BARF_UNLESS_UNSIGNED(v) \
    BUILD_ASSERT_OR_ZERO((((__typeof__(*v)) -1) > 0))

struct option_like {
    void *value;
    size_t precision;
};

struct context {
    size_t min_batch_size;
};

int main(void) {
    struct context ctx;
    struct option_like option = {
        .value = (&ctx.min_batch_size) + BARF_UNLESS_UNSIGNED(&ctx.min_batch_size),
        .precision = sizeof(*&ctx.min_batch_size),
    };
    return option.precision == sizeof(size_t) ? 0 : 1;
}
