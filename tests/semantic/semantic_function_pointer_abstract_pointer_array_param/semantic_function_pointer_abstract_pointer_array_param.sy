typedef unsigned long size_t;
typedef struct group_st GROUP;
typedef struct point_st POINT;
typedef struct ctx_st CTX;

struct methods_st {
    int (*points_make_affine)(const GROUP *, size_t num, POINT *[], CTX *);
};

int impl(const GROUP *group, size_t num, POINT *points[], CTX *ctx) {
    return points != (POINT **)0 && group != (GROUP *)0 && ctx != (CTX *)0
               ? (int)num
               : -1;
}

static struct methods_st methods = {
    .points_make_affine = impl,
};

int call_it(const GROUP *group, POINT **points, CTX *ctx) {
    return methods.points_make_affine(group, 3, points, ctx);
}
