enum schedule_priority {
    SCHEDULE_NONE,
    SCHEDULE_DAILY
};

enum task_label {
    TASK_GC,
    TASK_COMMIT_GRAPH,
    TASK__COUNT
};

struct maintenance_strategy {
    struct {
        unsigned type;
        enum schedule_priority schedule;
    } tasks[TASK__COUNT];
};

static const struct maintenance_strategy none_strategy = { 0 };

int main(void) {
    return none_strategy.tasks[TASK_GC].type;
}
