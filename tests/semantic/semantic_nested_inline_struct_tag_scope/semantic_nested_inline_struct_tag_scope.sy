struct WhereLevel {
    union {
        struct {
            int nIn;
            struct InLoop {
                int iCur;
                int addrInTop;
                unsigned char eEndLoopOp;
            } *aInLoop;
        } in;
    } u;
};

int f(struct WhereLevel *pLevel) {
    struct InLoop *pIn;
    pIn = pLevel->u.in.aInLoop;
    pIn->addrInTop = 1;
    return pIn->addrInTop + 1;
}
