static enum {
    UNBORN_IGNORE = 0,
    UNBORN_ALLOW,
    UNBORN_ADVERTISE
} unborn_config(void) {
    return UNBORN_ADVERTISE;
}

int advertise(void) {
    return unborn_config() == UNBORN_ADVERTISE;
}

typedef enum {
    REG_NOERROR = 0,
    REG_NOMATCH
} reg_errcode_t;

reg_errcode_t regex_status(void) {
    return REG_NOMATCH;
}
