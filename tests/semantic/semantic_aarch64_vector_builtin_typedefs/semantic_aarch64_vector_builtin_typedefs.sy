typedef __Float32x4_t __f32x4_t;
typedef __Float64x2_t __f64x2_t;
typedef __SVFloat32_t __sv_f32_t;
typedef __SVFloat64_t __sv_f64_t;
typedef __SVBool_t __sv_bool_t;

__f32x4_t *get_f32(__f32x4_t *value);
__f64x2_t *get_f64(__f64x2_t *value);
__sv_f32_t *get_sv_f32(__sv_f32_t *value);
__sv_f64_t *get_sv_f64(__sv_f64_t *value);
__sv_bool_t *get_sv_bool(__sv_bool_t *value);

