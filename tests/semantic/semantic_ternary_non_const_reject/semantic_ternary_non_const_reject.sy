// Test: Constant evaluator rejects non-constant ternary
// Bug coverage: Ensure ternary in const initializer is actually constant

int get_value(void) {
    return 42;
}

int main(void) {
    int runtime_val = get_value();
    // This should be rejected: runtime value in ternary
    const int x = (runtime_val > 0) ? 1 : 0;
    return x;
}
