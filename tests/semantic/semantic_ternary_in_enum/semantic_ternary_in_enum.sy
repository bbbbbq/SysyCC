// Test: Ternary operator in enum value constant expression
// Bug coverage: ConditionalExpr missing from evaluate_integer_expr()

enum {
    A = 1,
    B = 2,
    C = (A > B) ? A : B,  // Should evaluate to 2
    D = (A < B) ? A : B   // Should evaluate to 1
};

int get_c(void) {
    return C;
}

int get_d(void) {
    return D;
}

int main(void) {
    return (C != 2) || (D != 1);
}
