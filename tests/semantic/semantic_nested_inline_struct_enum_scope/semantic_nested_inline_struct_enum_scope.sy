struct outer {
    struct inner {
        enum {
            REV_CMD_REF,
            REV_CMD_PARENTS_ONLY,
            REV_CMD_LEFT,
            REV_CMD_RIGHT
        } whence;
    } *rev;
};

int classify(struct outer *value) {
    switch (value->rev->whence) {
    case REV_CMD_REF:
        return REV_CMD_PARENTS_ONLY;
    case REV_CMD_LEFT:
        return REV_CMD_RIGHT;
    }
    return 0;
}
