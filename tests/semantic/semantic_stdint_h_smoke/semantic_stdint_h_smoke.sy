#include <stdint.h>

int main(void) {
    int32_t signed_value = -7;
    uint64_t wide_value = 42ULL;
    intptr_t pointer_width = (intptr_t)&signed_value;
    uintptr_t unsigned_pointer_width = (uintptr_t)&wide_value;
    return signed_value < 0 && wide_value > 0ULL &&
                   pointer_width != (intptr_t)0 &&
                   unsigned_pointer_width != (uintptr_t)0
               ? 0
               : 1;
}
