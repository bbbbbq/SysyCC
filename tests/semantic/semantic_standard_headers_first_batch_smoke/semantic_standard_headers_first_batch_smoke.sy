#include <assert.h>
#include <ctype.h>
#include <float.h>
#include <stddef.h>
#include <stdlib.h>
#include <string.h>

int main(void) {
    size_t count = sizeof(int) * 2;
    void *buffer = malloc(count);
    ptrdiff_t delta = (char *)buffer - (char *)NULL;
    char dst[4];
    const char src[4] = "abc";
    int digit = isdigit('7');
    int radix = FLT_RADIX;

    memcpy(dst, src, sizeof(dst));
    assert(digit);
    if (buffer != NULL) {
        free(buffer);
    }
    return radix > 0 ? (int)(delta != 0) + dst[0] : 1;
}
