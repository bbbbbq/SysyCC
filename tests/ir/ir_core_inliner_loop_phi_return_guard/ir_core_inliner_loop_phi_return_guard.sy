unsigned long multmodp(unsigned long a, unsigned long b) {
    unsigned long m = (unsigned long)1 << 31;
    unsigned long p = 0;
    for (;;) {
        if (a & m) {
            p ^= b;
            if ((a & (m - 1)) == 0) {
                break;
            }
        }
        m >>= 1;
        b = b & 1 ? (b >> 1) ^ 0xedb88320 : b >> 1;
    }
    return p;
}

unsigned long table[32];

unsigned long x2nmodp(long n, unsigned k) {
    unsigned long p = (unsigned long)1 << 31;
    while (n) {
        if (n & 1) {
            p = multmodp(table[k & 31], p);
        }
        n >>= 1;
        k++;
    }
    return p;
}

int main(void) {
    table[0] = 3;
    return x2nmodp(1, 0) == 0 ? 1 : 0;
}
