int compare_float(float lhs, float rhs) {
    return lhs < rhs;
}

int compare_half(_Float16 lhs, _Float16 rhs) {
    return lhs != rhs;
}

int compare_double(double lhs, double rhs) {
    return lhs == rhs;
}

int compare_long_double(long double lhs, long double rhs) {
    return lhs > rhs;
}

int branch_float(float value) {
    if (value) {
        return 1;
    }
    return 0;
}

int branch_half(_Float16 value) {
    return value ? 2 : 3;
}

int branch_double(double value) {
    if (value) {
        return 4;
    }
    return 5;
}

int branch_long_double(long double value) {
    return value ? 6 : 7;
}

int main() {
    return 0;
}
