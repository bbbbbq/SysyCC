int leaf(int x) {
    return x + 1;
}

int left(int x);
int right(int x);

int left(int x) {
    if (x <= 0) {
        return leaf(x);
    }
    return right(x - 1) + leaf(x);
}

int right(int x) {
    if (x <= 0) {
        return leaf(x);
    }
    return left(x - 1) + leaf(x);
}

int root(int x) {
    return left(x) + right(x) + leaf(x);
}

int main() {
    return root(3) == 24 ? 0 : 1;
}
