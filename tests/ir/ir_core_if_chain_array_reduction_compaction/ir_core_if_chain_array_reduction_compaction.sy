int func(int n, int i) {
    int sum = 0;
    int j = 0;
    int s[8];
    int m = 0;

    while (m < 8) {
        s[m] = 0;
        m = m + 1;
    }

    while (j < n) {
        if (i > 1) {
            s[1] = 1;
            if (i > 2) {
                s[2] = 2;
                if (i > 3) {
                    s[3] = 3;
                    if (i > 4) {
                        s[4] = 4;
                        if (i > 5) {
                            s[5] = 5;
                            if (i > 6) {
                                s[6] = 6;
                                if (i > 7) {
                                    s[7] = 7;
                                }
                            }
                        }
                    }
                }
            }
        }
        j = j + 1;
        m = 0;
        while (m < 8) {
            sum = sum + s[m];
            m = m + 1;
        }
        sum = sum % 65535;
    }

    return sum;
}

int main() {
    return func(getint(), getint());
}
