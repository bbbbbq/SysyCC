int limit;

int loopified_scalar(int n, int depth) {
    if (n == 1) {
        return depth;
    }
    if (n % 2 == 0) {
        return loopified_scalar(n / 2, depth + 1);
    }
    if (n * 3 + 1 <= limit) {
        return loopified_scalar(n * 3 + 1, depth + 1);
    }
    return 0;
}

int main() {
    limit = getint();
    int sum = 0;
    int i = 1;
    while (i <= limit) {
        sum = sum + loopified_scalar(i, 0);
        i = i + 1;
    }
    return sum;
}
