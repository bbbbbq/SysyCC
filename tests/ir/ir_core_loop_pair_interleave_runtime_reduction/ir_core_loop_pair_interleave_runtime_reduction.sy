const int N = 128;

int A[N][N];
int b[N];
int x[N];
int y[N];

void pair_reduce(int n, int A[][128], int b[], int x[], int y[]) {
    int i;
    int j;
    int k;
    int w;

    i = 0;
    while (i < n) {
        j = 0;
        while (j < i) {
            w = A[i][j];
            k = 0;
            while (k < j) {
                w = w - A[i][k] * A[k][j];
                k = k + 1;
            }
            A[i][j] = w;
            j = j + 1;
        }
        i = i + 1;
    }
}

int main() {
    pair_reduce(getint(), A, b, x, y);
    return 0;
}
