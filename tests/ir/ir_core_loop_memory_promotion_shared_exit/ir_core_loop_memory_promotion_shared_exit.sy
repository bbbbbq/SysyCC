extern unsigned long strtoul(const char *, char **, int);
extern int isdigit(int);

int parse_cutoff(const char *p) {
    char *end;
    int permille = strtoul(p, &end, 10) * 10;
    if (*end == 46 && isdigit(*++end)) {
        permille += *end - 48;
        while (isdigit(*++end)) {
        }
    }
    if (!*end) {
        return permille;
    }
    return 1;
}
