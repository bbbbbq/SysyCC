// Test: Function pointer call with explicit dereference form (*fp)(args)
// Bug coverage: Function pointer callee type retrieval inconsistency
// Both fp(args) and (*fp)(args) forms should work identically

int inc(int x) {
    return x + 1;
}

int main(void) {
    int (*fn)(int) = inc;

    // Form 1: direct function pointer call
    int r1 = fn(4);

    // Form 2: explicit dereference call
    int r2 = (*fn)(4);

    // Both forms should produce the same result
    return (r1 != 5) || (r2 != 5);
}
