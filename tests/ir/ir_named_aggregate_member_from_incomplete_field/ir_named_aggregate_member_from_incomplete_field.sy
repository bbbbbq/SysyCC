typedef struct Thread {
    struct Global *global;
} Thread;

typedef struct Table {
    int value;
} Table;

typedef struct Global {
    struct Table *metatables[9];
    int nilvalue;
} Global;

int read_nil(Thread *thread) {
    return thread->global->nilvalue;
}

int update(Thread *thread, int tag, Table *table) {
    Table *old = thread->global->metatables[tag];
    thread->global->metatables[tag] = table;
    return old == table ? read_nil(thread) : 0;
}

int main(void) {
    return 0;
}
