const int N = 4;

void mm(int n, int A[][N], int B[][N], int C[][N]) {
    int i, j, k;

    i = 0;
    j = 0;
    while (i < n) {
        j = 0;
        while (j < n) {
            C[i][j] = 0;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    j = 0;
    k = 0;
    while (k < n) {
        i = 0;
        while (i < n) {
            if (A[i][k] == 0) {
                i = i + 1;
                continue;
            }
            j = 0;
            while (j < n) {
                C[i][j] = C[i][j] + A[i][k] * B[k][j];
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
}

int A[N][N];
int B[N][N];
int C[N][N];

int main() {
    mm(4, A, B, C);
    return C[0][0];
}
