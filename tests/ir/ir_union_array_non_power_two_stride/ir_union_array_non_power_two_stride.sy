struct Payload {
    int left;
    signed char tag;
    unsigned int right;
};

union Slot {
    struct Payload payload;
    int raw;
};

static union Slot g_slots[2] = {
    {{1, 2, 3}},
    {{4, 5, 6}}
};

int main() {
    return g_slots[1].payload.left + g_slots[1].payload.tag + g_slots[1].payload.right;
}
