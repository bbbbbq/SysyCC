typedef unsigned char byte;

typedef struct Inner {
    int tag;
} Inner;

typedef struct Wrapper {
    byte padding[8];
    Inner inner;
} Wrapper;

typedef struct Root {
    int header;
    Wrapper wrapper;
} Root;

extern void *alloc(void);

Inner *select_inner(void) {
    Root *root = (Root *)alloc();
    Inner *inner = &root->wrapper.inner;
    inner->tag = 8;
    return inner;
}

int main() {
    return 0;
}
