int guarded_mul(int a, int b) {
    return ((a > 0 && b > 0 && a > 2147483647 / b) ||
            (a > 0 && b <= 0 && b < (-2147483647 - 1) / a) ||
            (a <= 0 && b > 0 && a < (-2147483647 - 1) / b) ||
            (a <= 0 && b <= 0 && a != 0 && b < 2147483647 / a))
               ? a
               : a * b;
}

int main() {
    int i = 0;
    int value = 1;

    while (i < 200000) {
        value = guarded_mul(value, 1);
        i = i + 1;
    }

    return value;
}
