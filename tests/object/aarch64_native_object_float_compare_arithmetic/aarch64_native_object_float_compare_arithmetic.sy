float blend(float a, float b) {
    float value;
    value = a - b;
    value = value * b;
    value = value / a;
    if (value < b) {
        value = value + 1.0f;
    }
    return value;
}

int main(void) {
    float x;
    float y;
    x = (float)getint();
    y = (float)getint();
    putint((int)blend(x, y));
    return 0;
}
