int inc(int x) { return x + 1; }

int call_indirect(int (*fp)(int), int *p) {
    int x0 = p[0];
    int x1 = p[1];
    int x2 = p[2];
    int x3 = p[3];
    return fp(x0 + x1 + x2 + x3);
}

int main() {
    int data[4];
    data[0] = 1;
    data[1] = 2;
    data[2] = 3;
    data[3] = 4;
    putint(call_indirect(inc, data));
    return 0;
}
