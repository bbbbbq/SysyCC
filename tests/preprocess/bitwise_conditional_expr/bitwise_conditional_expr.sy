#define FLAGS 6

#if ((FLAGS & 2) == 2)
int bitand_branch() {
    return 1;
}
#else
int bitand_branch() {
    return 0;
}
#endif

#if ((FLAGS | 1) == 7)
int bitor_branch() {
    return 2;
}
#else
int bitor_branch() {
    return 0;
}
#endif

#if ((FLAGS ^ 3) == 5)
int bitxor_branch() {
    return 4;
}
#else
int bitxor_branch() {
    return 0;
}
#endif

#if ((8 >> 2) == 2)
int shr_branch() {
    return 8;
}
#else
int shr_branch() {
    return 0;
}
#endif

#if ((1 << 3) == 8)
int shl_branch() {
    return 16;
}
#else
int shl_branch() {
    return 0;
}
#endif

#if (~0)
int bitnot_branch() {
    return 32;
}
#else
int bitnot_branch() {
    return 0;
}
#endif

int main() {
    return bitand_branch() + bitor_branch() + bitxor_branch() +
           shr_branch() + shl_branch() + bitnot_branch();
}
