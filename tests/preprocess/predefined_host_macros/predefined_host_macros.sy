#if !defined(__STDC__) || (__STDC__ != 1)
#error missing __STDC__
#endif

#if !defined(__STDC_HOSTED__) || (__STDC_HOSTED__ != 1)
#error missing __STDC_HOSTED__
#endif

#if !defined(__STDC_VERSION__) || (__STDC_VERSION__ < 201710L)
#error missing __STDC_VERSION__
#endif

#if !defined(__APPLE__) || !defined(__MACH__)
#error missing Apple host macros
#endif

#if !defined(__LP64__)
#error missing LP64 host macro
#endif

#if !(defined(__arm64__) || defined(__aarch64__) || defined(__x86_64__))
#error missing host architecture macro
#endif

#if !defined(__clang__) || !defined(__GNUC__)
#error missing compiler identity macros
#endif

int predefined_host_macros_ready = 1;
