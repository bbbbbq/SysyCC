#if __INT16_MAX__ >= __INT_MAX__
int int16_ge_int() {
    return 1;
}
#else
int int16_ge_int() {
    return 0;
}
#endif

#if __INT32_MAX__ >= __INT_MAX__
int int32_ge_int() {
    return 1;
}
#else
int int32_ge_int() {
    return 0;
}
#endif

#if __CHAR_BIT__ == 8
int char_bit_is_eight() {
    return 1;
}
#else
int char_bit_is_eight() {
    return 0;
}
#endif

int main() {
    return int16_ge_int() + int32_ge_int() + char_bit_is_eight();
}
