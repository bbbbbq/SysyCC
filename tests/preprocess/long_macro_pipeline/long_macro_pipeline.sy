#define BUILD_PAIR_SUM(lhs, rhs) \
    ((lhs) + (rhs))
#define DECLARE_VALUE(name, expr) \
    int name = expr;
#define CAT(a, b) a##b
#define EXPAND(x) x
#define FORWARD(...) __VA_ARGS__
#define BASE_VALUE 6
#define ALIAS_BASE BASE_VALUE
#define EXTRA_VALUE 4
#define EXTRA_ALIAS EXTRA_VALUE
#define SELECT(prefix) CAT(prefix, _value)
#define DECLARE_SELECTED(prefix, expr) \
    DECLARE_VALUE(SELECT(prefix), expr)
#define DECLARE_CHAINED(name, left, right) \
    DECLARE_VALUE(name, FORWARD(BUILD_PAIR_SUM(left, right)))

DECLARE_SELECTED(alpha, ALIAS_BASE)
DECLARE_SELECTED(beta, EXPAND(EXTRA_ALIAS))
DECLARE_CHAINED(gamma_value, alpha_value, beta_value)
DECLARE_CHAINED(delta_value, gamma_value, 3)

#if defined BASE_VALUE && defined EXTRA_ALIAS
DECLARE_CHAINED(condition_value, delta_value, 1)
#else
DECLARE_VALUE(condition_value, 0)
#endif

#ifndef NEVER_DEFINED
DECLARE_CHAINED(fallback_value, condition_value, 2)
#endif

int main() {
    return fallback_value;
}
