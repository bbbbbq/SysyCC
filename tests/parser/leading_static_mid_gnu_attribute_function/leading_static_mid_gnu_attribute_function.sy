typedef long off_t;

__attribute__((format(printf, 2, 3)))
static __attribute__((noreturn)) void bad_object(off_t offset,
                                                 const char *format, ...) {
    (void)offset;
    (void)format;
    for (;;) {
    }
}

__attribute__((format(printf, 2, 3)))
static __attribute__((noreturn)) void bad_decl(off_t offset,
                                               const char *format, ...);
