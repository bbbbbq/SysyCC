typedef signed long int signed_long_alias;
typedef signed long long int signed_long_long_alias;
typedef unsigned long long int unsigned_long_long_alias;

signed_long_alias value = 1;
signed_long_long_alias wide_value = 2;
unsigned_long_long_alias unsigned_wide_value = 3;

int main(void) {
    return (int)value + (int)wide_value + (int)unsigned_wide_value;
}
