typedef void (*report_fn)(const char *);

void set_die_routine(__attribute__((__noreturn__)) report_fn routine);

void set_die_routine(__attribute__((__noreturn__)) report_fn routine) {
    routine("fatal");
}

void reporter(const char *message) {
    (void)message;
}

int main(void) {
    set_die_routine(reporter);
    return 0;
}
