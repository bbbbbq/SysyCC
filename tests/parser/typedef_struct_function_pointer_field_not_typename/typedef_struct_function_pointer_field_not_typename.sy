typedef struct cert_st Cert;

typedef struct purpose_st {
    int purpose;
    int (*check_purpose)(const struct purpose_st *, const Cert *, int);
} Purpose;

static int check_purpose(int ctx, int cert, int purpose, int depth,
                         int must_be_ca) {
    (void)ctx;
    (void)cert;
    (void)depth;
    (void)must_be_ca;
    return purpose;
}

int verify(int purpose, int ctx, int cert, int depth, int must_be_ca) {
    if (purpose >= 1 && !check_purpose(ctx, cert, purpose, depth, must_be_ca)) {
        return 0;
    }
    return 1;
}
