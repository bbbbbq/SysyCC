void target(void) {
}

void *lookup(void *handle, const char *name) {
    (void)handle;
    (void)name;
    return (void *)&target;
}

int main(void) {
    void (*(*x)(void *, const char *))(void);
    x = (void (*(*)(void *, const char *))(void))lookup;
    (*x)((void *)0, "target")();
    return 0;
}
