#define _ISbit(bit) ((bit) < 8 ? ((1 << (bit)) << 8) : ((1 << (bit)) >> 8))

enum {
    E0 = _ISbit(0),
    E1 = _ISbit(1),
    E2 = _ISbit(2),
    E3 = _ISbit(3),
    E4 = _ISbit(4),
    E5 = _ISbit(5),
    E6 = _ISbit(6),
    E7 = _ISbit(7),
    E8 = _ISbit(8),
    E9 = _ISbit(9),
    E10 = _ISbit(10),
    E11 = _ISbit(11)
};

int main() {
    return E6 == 0 ? 1 : 0;
}
