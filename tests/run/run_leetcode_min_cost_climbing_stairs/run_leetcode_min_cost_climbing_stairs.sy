// Source: LeetCode 746. Min Cost Climbing Stairs
// Problem: https://leetcode.com/problems/min-cost-climbing-stairs/
// Adapted for SysyCC runtime regression: read n and stair costs, then print
// the minimum total cost to reach the top.

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int min_cost(int values[32], int count) {
    int prev_two = 0;
    int prev_one = 0;
    int next_value = 0;
    int i = 2;

    while (i <= count) {
        next_value = min_int(prev_one + values[i - 1], prev_two + values[i - 2]);
        prev_two = prev_one;
        prev_one = next_value;
        i = i + 1;
    }

    return prev_one;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(min_cost(values, count));
    putch(10);
    return 0;
}
