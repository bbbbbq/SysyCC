// Source: LeetCode 169. Majority Element
// Problem: https://leetcode.com/problems/majority-element/
// Discuss reference: https://leetcode.com/discuss/post/136594/majority-problem-set-summary-c/
// Adapted for SysyCC runtime regression: read n and an integer array, then
// print the majority element using Boyer-Moore voting.

int majority_vote(int values[16], int count) {
    int candidate = 0;
    int balance = 0;
    int i = 0;

    while (i < count) {
        if (balance == 0) {
            candidate = values[i];
            balance = 1;
        } else {
            if (values[i] == candidate) {
                balance = balance + 1;
            } else {
                balance = balance - 1;
            }
        }
        i = i + 1;
    }

    return candidate;
}

int main() {
    int values[16];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(majority_vote(values, count));
    putch(10);
    return 0;
}
