// Source: LeetCode 20. Valid Parentheses
// Problem: https://leetcode.com/problems/valid-parentheses/
// Adapted for SysyCC runtime regression: read n and an integer-encoded bracket
// stream where 1/2/3 mean opening (), [], {} and -1/-2/-3 mean closing
// brackets, then print 1 if the sequence is valid, otherwise 0.

int is_match(int open_value, int close_value) {
    return open_value + close_value == 0;
}

int is_valid(int values[32], int count) {
    int stack[32];
    int top = 0;
    int i = 0;

    while (i < count) {
        if (values[i] > 0) {
            stack[top] = values[i];
            top = top + 1;
        } else {
            if (top == 0) {
                return 0;
            }
            if (!is_match(stack[top - 1], values[i])) {
                return 0;
            }
            top = top - 1;
        }
        i = i + 1;
    }

    return top == 0;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(is_valid(values, count));
    putch(10);
    return 0;
}
