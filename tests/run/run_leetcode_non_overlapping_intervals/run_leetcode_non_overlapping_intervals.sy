// Source: LeetCode 435. Non-overlapping Intervals
// Problem: https://leetcode.com/problems/non-overlapping-intervals/
// Adapted for SysyCC runtime regression: read n intervals, greedily remove the
// minimum number to avoid overlap, and print that count.

int starts[32];
int ends[32];

void swap_int(int values[32], int lhs, int rhs) {
    int temp = values[lhs];
    values[lhs] = values[rhs];
    values[rhs] = temp;
}

void sort_by_end(int count) {
    int i = 0;
    int j = 0;

    i = 0;
    while (i < count) {
        j = i + 1;
        while (j < count) {
            if (ends[j] < ends[i]) {
                swap_int(starts, i, j);
                swap_int(ends, i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

int main() {
    int count = 0;
    int removed = 0;
    int keep_end = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        starts[i] = getint();
        ends[i] = getint();
        i = i + 1;
    }

    sort_by_end(count);

    keep_end = ends[0];
    i = 1;
    while (i < count) {
        if (starts[i] < keep_end) {
            removed = removed + 1;
        } else {
            keep_end = ends[i];
        }
        i = i + 1;
    }

    putint(removed);
    putch(10);
    return 0;
}
