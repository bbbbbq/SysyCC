struct JumpBufTag {
    long slots[4];
};

typedef struct JumpBufTag jump_buffer[1];
typedef void (*jump_fn)(jump_buffer, int);

int observed = 0;

void jump_impl(jump_buffer env, int value) {
    observed = (int)env[0].slots[0] + value;
}

int main(void) {
    jump_buffer local;
    jump_buffer *ptr = &local;
    jump_fn fn = (jump_fn)jump_impl;
    local[0].slots[0] = 40;
    fn(*ptr, 2);
    return observed == 42 ? 0 : 1;
}
