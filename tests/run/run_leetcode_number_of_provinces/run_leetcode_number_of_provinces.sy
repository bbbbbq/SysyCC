// Source: LeetCode 547. Number of Provinces
// Problem: https://leetcode.com/problems/number-of-provinces/
// Adapted for SysyCC runtime regression: read n and an adjacency matrix, then
// print the number of connected components using union-find.

int parent_set[16];
int rank_set[16];

int find_root(int value) {
    while (parent_set[value] != value) {
        parent_set[value] = parent_set[parent_set[value]];
        value = parent_set[value];
    }
    return value;
}

void union_sets(int lhs, int rhs) {
    int left_root = find_root(lhs);
    int right_root = find_root(rhs);

    if (left_root == right_root) {
        return;
    }

    if (rank_set[left_root] < rank_set[right_root]) {
        parent_set[left_root] = right_root;
    } else {
        if (rank_set[left_root] > rank_set[right_root]) {
            parent_set[right_root] = left_root;
        } else {
            parent_set[right_root] = left_root;
            rank_set[left_root] = rank_set[left_root] + 1;
        }
    }
}

int main() {
    int cities = 0;
    int i = 0;
    int j = 0;
    int provinces = 0;
    int is_connected = 0;

    cities = getint();
    i = 0;
    while (i < cities) {
        parent_set[i] = i;
        rank_set[i] = 0;
        i = i + 1;
    }

    i = 0;
    while (i < cities) {
        j = 0;
        while (j < cities) {
            is_connected = getint();
            if (j > i && is_connected) {
                union_sets(i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < cities) {
        if (find_root(i) == i) {
            provinces = provinces + 1;
        }
        i = i + 1;
    }

    putint(provinces);
    putch(10);
    return 0;
}
