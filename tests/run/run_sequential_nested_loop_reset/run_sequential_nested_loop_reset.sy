int main() {
    int n = 2;
    int i = 0;
    int j = 0;
    int sum = 0;

    while (i < n) {
        j = 0;
        while (j < n) {
            sum = sum + 1;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    j = 0;
    while (i < n) {
        j = 0;
        while (j < n) {
            sum = sum + 10;
            j = j + 1;
        }
        i = i + 1;
    }

    putint(sum);
    putch(10);
    return 0;
}
