// Source: LeetCode 743. Network Delay Time
// Problem: https://leetcode.com/problems/network-delay-time/
// Adapted for SysyCC runtime regression: read node count, edge count, source,
// and weighted directed edges, then print the maximum shortest-path distance
// using Dijkstra with a handwritten min-heap.

int graph_weight[16][16];
int best_dist[16];
int heap_dist[128];
int heap_node[128];
int visited[16];

void swap_heap(int lhs, int rhs) {
    int temp_dist = heap_dist[lhs];
    int temp_node = heap_node[lhs];
    heap_dist[lhs] = heap_dist[rhs];
    heap_node[lhs] = heap_node[rhs];
    heap_dist[rhs] = temp_dist;
    heap_node[rhs] = temp_node;
}

void sift_up(int index) {
    int parent = 0;
    while (index > 0) {
        parent = (index - 1) / 2;
        if (heap_dist[parent] < heap_dist[index] ||
            (heap_dist[parent] == heap_dist[index] && heap_node[parent] <= heap_node[index])) {
            return;
        }
        swap_heap(parent, index);
        index = parent;
    }
}

void sift_down(int count, int index) {
    int child = 0;
    int best = 0;
    while (1) {
        child = index * 2 + 1;
        if (child >= count) {
            return;
        }
        best = child;
        if (child + 1 < count &&
            (heap_dist[child + 1] < heap_dist[child] ||
             (heap_dist[child + 1] == heap_dist[child] && heap_node[child + 1] < heap_node[child]))) {
            best = child + 1;
        }
        if (heap_dist[index] < heap_dist[best] ||
            (heap_dist[index] == heap_dist[best] && heap_node[index] <= heap_node[best])) {
            return;
        }
        swap_heap(index, best);
        index = best;
    }
}

void push_heap(int *count, int dist, int node) {
    heap_dist[*count] = dist;
    heap_node[*count] = node;
    *count = *count + 1;
    sift_up(*count - 1);
}

void pop_heap(int *count) {
    *count = *count - 1;
    heap_dist[0] = heap_dist[*count];
    heap_node[0] = heap_node[*count];
    sift_down(*count, 0);
}

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int main() {
    int node_count = 0;
    int edge_count = 0;
    int source = 0;
    int from = 0;
    int to = 0;
    int weight = 0;
    int i = 0;
    int j = 0;
    int heap_size = 0;
    int node = 0;
    int dist = 0;
    int answer = 0;

    node_count = getint();
    edge_count = getint();
    source = getint();

    i = 0;
    while (i < node_count) {
        best_dist[i] = 1000000;
        visited[i] = 0;
        j = 0;
        while (j < node_count) {
            graph_weight[i][j] = 1000000;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < edge_count) {
        from = getint() - 1;
        to = getint() - 1;
        weight = getint();
        if (weight < graph_weight[from][to]) {
            graph_weight[from][to] = weight;
        }
        i = i + 1;
    }

    best_dist[source - 1] = 0;
    push_heap(&heap_size, 0, source - 1);

    while (heap_size > 0) {
        dist = heap_dist[0];
        node = heap_node[0];
        pop_heap(&heap_size);

        if (visited[node]) {
            continue;
        }
        visited[node] = 1;

        j = 0;
        while (j < node_count) {
            if (graph_weight[node][j] < 1000000 &&
                dist + graph_weight[node][j] < best_dist[j]) {
                best_dist[j] = dist + graph_weight[node][j];
                push_heap(&heap_size, best_dist[j], j);
            }
            j = j + 1;
        }
    }

    i = 0;
    while (i < node_count) {
        if (best_dist[i] >= 1000000) {
            putint(-1);
            putch(10);
            return 0;
        }
        answer = max_int(answer, best_dist[i]);
        i = i + 1;
    }

    putint(answer);
    putch(10);
    return 0;
}
