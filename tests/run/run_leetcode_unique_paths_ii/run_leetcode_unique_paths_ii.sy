// Source: LeetCode 63. Unique Paths II
// Problem: https://leetcode.com/problems/unique-paths-ii/
// Adapted for SysyCC runtime regression: read rows, cols, and an obstacle grid,
// then print the number of unique paths from top-left to bottom-right.

int obstacle[8][8];
int dp[8][8];

int main() {
    int rows = 0;
    int cols = 0;
    int i = 0;
    int j = 0;

    rows = getint();
    cols = getint();

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            obstacle[i][j] = getint();
            dp[i][j] = 0;
            j = j + 1;
        }
        i = i + 1;
    }

    if (obstacle[0][0] == 0) {
        dp[0][0] = 1;
    }

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            if (obstacle[i][j] == 1) {
                dp[i][j] = 0;
            } else {
                if (!(i == 0 && j == 0)) {
                    if (i > 0) {
                        dp[i][j] = dp[i][j] + dp[i - 1][j];
                    }
                    if (j > 0) {
                        dp[i][j] = dp[i][j] + dp[i][j - 1];
                    }
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }

    putint(dp[rows - 1][cols - 1]);
    putch(10);
    return 0;
}
