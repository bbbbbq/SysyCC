int is_sep(char c) {
    return c == '/';
}

int check_name(const char *name) {
    if (!*name) {
        return -1;
    }

    goto in_component;
    while (*name) {
        char c = *name++;
        if (is_sep(c)) {
in_component:
            if (name[0] == '.' && name[1] == '.' &&
                (!name[2] || is_sep(name[2]))) {
                return -1;
            }
        }
    }

    return 0;
}

int main(void) {
    return check_name("a/..") == -1 && check_name("module/path") == 0 ? 0 : 1;
}
