int main(void) {
    int value = 3;
    int loaded = 0;
    int desired = 19;
    int *expected = &value;

    if (!__atomic_is_lock_free(sizeof(value), &value)) {
        return 1;
    }
    if (__atomic_add_fetch(&value, 4, 4) != 7) {
        return 2;
    }
    if (__atomic_sub_fetch(&value, 2, 0) != 5) {
        return 3;
    }
    if (__atomic_or_fetch(&value, 8, 0) != 13) {
        return 4;
    }
    if (__atomic_and_fetch(&value, 12, 0) != 12) {
        return 5;
    }
    __atomic_load(&value, &loaded, 2);
    if (loaded != 12) {
        return 6;
    }
    __atomic_store(&value, &desired, 3);
    if (value != 19) {
        return 7;
    }
    if (!__atomic_compare_exchange_n(&expected, &expected, &value, 0, 4, 0)) {
        return 8;
    }
    return 0;
}
