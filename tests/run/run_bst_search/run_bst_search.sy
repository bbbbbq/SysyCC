int main() {
    int root = getint();
    int left = getint();
    int right = getint();
    int target = getint();
    int cursor = 1;
    int found = 0;

    while (cursor != 0 && found == 0) {
        if (cursor == 1) {
            if (target == root) {
                found = 1;
            } else {
                if (target < root) {
                    cursor = 2;
                } else {
                    cursor = 3;
                }
            }
        } else {
            if (cursor == 2) {
                if (target == left) {
                    found = 1;
                } else {
                    cursor = 0;
                }
            } else {
                if (target == right) {
                    found = 1;
                } else {
                    cursor = 0;
                }
            }
        }
    }

    putint(found);
    putch(10);
    return 0;
}
