struct Payload {
    int left;
    signed char tag;
    unsigned int right;
};

union Slot {
    struct Payload payload;
    int raw;
};

static union Slot g_slots[2] = {
    {{1, 2, 3}},
    {{4, 5, 6}}
};

int main() {
    putint(g_slots[0].payload.left);
    putch(32);
    putint(g_slots[1].payload.left);
    putch(32);
    putint(g_slots[1].payload.tag);
    putch(32);
    putint(g_slots[1].payload.right);
    putch(10);
    return 0;
}
