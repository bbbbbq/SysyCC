// Source: LeetCode 198. House Robber
// Problem: https://leetcode.com/problems/house-robber/
// Adapted for SysyCC runtime regression: read n and house values, then print
// the maximum non-adjacent robbery sum.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int rob_linear(int values[32], int count) {
    int prev_two = 0;
    int prev_one = 0;
    int i = 0;
    int next_value = 0;

    while (i < count) {
        next_value = max_int(prev_one, prev_two + values[i]);
        prev_two = prev_one;
        prev_one = next_value;
        i = i + 1;
    }

    return prev_one;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(rob_linear(values, count));
    putch(10);
    return 0;
}
