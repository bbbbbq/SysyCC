// Source: LeetCode 54. Spiral Matrix
// Problem: https://leetcode.com/problems/spiral-matrix/
// Adapted for SysyCC runtime regression: read rows, cols, and a matrix, then
// print the spiral traversal result.

int main() {
    int matrix[6][6];
    int rows = 0;
    int cols = 0;
    int top = 0;
    int bottom = 0;
    int left = 0;
    int right = 0;
    int i = 0;
    int j = 0;

    rows = getint();
    cols = getint();

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            matrix[i][j] = getint();
            j = j + 1;
        }
        i = i + 1;
    }

    bottom = rows - 1;
    right = cols - 1;
    while (top <= bottom && left <= right) {
        j = left;
        while (j <= right) {
            putint(matrix[top][j]);
            putch(10);
            j = j + 1;
        }
        top = top + 1;

        i = top;
        while (i <= bottom) {
            putint(matrix[i][right]);
            putch(10);
            i = i + 1;
        }
        right = right - 1;

        if (top <= bottom) {
            j = right;
            while (j >= left) {
                putint(matrix[bottom][j]);
                putch(10);
                j = j - 1;
            }
            bottom = bottom - 1;
        }

        if (left <= right) {
            i = bottom;
            while (i >= top) {
                putint(matrix[i][left]);
                putch(10);
                i = i - 1;
            }
            left = left + 1;
        }
    }

    return 0;
}
