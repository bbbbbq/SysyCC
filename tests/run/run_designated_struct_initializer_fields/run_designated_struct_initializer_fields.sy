struct item {
    char *string;
    void *util;
};

struct string_list {
    struct item *items;
    unsigned long nr;
    unsigned long alloc;
    unsigned int strdup_strings:1;
    int (*cmp)(const char *, const char *);
};

struct strbuf {
    unsigned long alloc;
    unsigned long len;
    char *buf;
};

struct nested_flags {
    unsigned int recursive:1;
    unsigned int quick:1;
};

struct nested_pruning {
    struct nested_flags flags;
};

struct rev_info {
    int abbrev;
    unsigned int simplify_history:1;
    struct nested_pruning pruning;
    int sort_order;
    long max_age;
};

struct backfill_context {
    struct rev_info revs;
};

enum option_type {
    OPTION_END,
    OPTION_CALLBACK
};

struct option {
    enum option_type type;
    int short_name;
    const char *long_name;
    void *value;
    unsigned long precision;
    const char *argh;
    const char *help;
    unsigned int flags;
    int (*callback)(const struct option *, const char *, int);
    long defval;
};

static char slopbuf[1];
static int use_color;
static struct string_list output = { .strdup_strings = 1 };
static struct strbuf buffer = { .buf = slopbuf };
static struct backfill_context global_ctx = {
    .revs = {
        .abbrev = 7,
        .simplify_history = 1,
        .pruning.flags.recursive = 1,
        .pruning.flags.quick = 1,
        .sort_order = 3,
        .max_age = -1,
    },
};

int parse_color(const struct option *option, const char *arg, int unset) {
    return option->type + arg[0] + unset;
}

int main() {
    struct option color = {
        .type = OPTION_CALLBACK,
        .short_name = 0,
        .long_name = "color",
        .value = &use_color,
        .argh = "when",
        .help = "use colored output",
        .flags = 7,
        .callback = parse_color,
        .defval = (long)"always",
    };

    putint(output.items == 0);
    putint(output.nr == 0);
    putint(output.alloc == 0);
    putint(output.strdup_strings == 1);
    putint(output.cmp == 0);
    putint(buffer.alloc == 0);
    putint(buffer.len == 0);
    putint(buffer.buf == slopbuf);
    putint(color.type == OPTION_CALLBACK);
    putint(color.long_name[0] == 'c');
    putint(color.value == &use_color);
    putint(color.precision == 0);
    putint(color.argh[0] == 'w');
    putint(color.flags == 7);
    putint(color.callback == parse_color);
    putint(color.defval != 0);
    putint(global_ctx.revs.abbrev == 7);
    putint(global_ctx.revs.simplify_history == 1);
    putint(global_ctx.revs.pruning.flags.recursive == 1);
    putint(global_ctx.revs.pruning.flags.quick == 1);
    putint(global_ctx.revs.sort_order == 3);
    putint(global_ctx.revs.max_age == -1);
    putch(10);
    return 0;
}
