union Box {
    unsigned int word;
};

static union Box make_box(unsigned int value) {
    union Box box = {value};
    return box;
}

static int read_box(union Box box) {
    return (int)box.word;
}

int main() {
    union Box box = {0};
    putint(read_box(box = make_box(7)));
    putch(10);
    return 0;
}
