#include <stdio.h>
#include <stdlib.h>

int main(void) {
    int count = 0;
    int i = 0;
    int sum = 0;
    int *values = (int *)0;

    if (scanf("%d", &count) != 1) {
        return 1;
    }

    values = (int *)malloc((unsigned long)(sizeof(int) * count));
    if (values == (int *)0) {
        printf("-1\n");
        return 0;
    }

    i = 0;
    while (i < count) {
        if (scanf("%d", &values[i]) != 1) {
            free(values);
            return 1;
        }
        sum = sum + values[i];
        i = i + 1;
    }

    free(values);
    printf("%d\n", sum);
    return 0;
}
