// Source: LeetCode 53. Maximum Subarray
// Problem: https://leetcode.com/problems/maximum-subarray/
// Discuss reference: https://leetcode.com/discuss/post/6751193/
// Adapted for SysyCC runtime regression: read n and an integer array, then
// print the maximum contiguous subarray sum using Kadane's algorithm.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int max_subarray_sum(int values[16], int count) {
    int best = values[0];
    int current = values[0];
    int i = 1;

    while (i < count) {
        current = max_int(values[i], current + values[i]);
        best = max_int(best, current);
        i = i + 1;
    }

    return best;
}

int main() {
    int values[16];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(max_subarray_sum(values, count));
    putch(10);
    return 0;
}
