// Source: LeetCode 200. Number of Islands
// Problem: https://leetcode.com/problems/number-of-islands/
// Adapted for SysyCC runtime regression: read rows, cols, and a 0/1 grid, then
// print the island count using DFS.

int g_grid[6][6];
int g_rows = 0;
int g_cols = 0;

void flood(int row, int col) {
    if (row < 0 || row >= g_rows || col < 0 || col >= g_cols) {
        return;
    }
    if (g_grid[row][col] == 0) {
        return;
    }

    g_grid[row][col] = 0;
    flood(row + 1, col);
    flood(row - 1, col);
    flood(row, col + 1);
    flood(row, col - 1);
}

int main() {
    int islands = 0;
    int i = 0;
    int j = 0;

    g_rows = getint();
    g_cols = getint();

    i = 0;
    while (i < g_rows) {
        j = 0;
        while (j < g_cols) {
            g_grid[i][j] = getint();
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < g_rows) {
        j = 0;
        while (j < g_cols) {
            if (g_grid[i][j] == 1) {
                islands = islands + 1;
                flood(i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    putint(islands);
    putch(10);
    return 0;
}
