// Source: LeetCode 739. Daily Temperatures
// Problem: https://leetcode.com/problems/daily-temperatures/
// Adapted for SysyCC runtime regression: read n and temperatures, then print
// waiting days for the next warmer temperature using a monotonic stack.

void daily_temperatures(int values[32], int count, int result[32]) {
    int stack[32];
    int top = 0;
    int i = 0;

    while (i < count) {
        result[i] = 0;
        while (top > 0 && values[i] > values[stack[top - 1]]) {
            result[stack[top - 1]] = i - stack[top - 1];
            top = top - 1;
        }
        stack[top] = i;
        top = top + 1;
        i = i + 1;
    }
}

int main() {
    int values[32];
    int result[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    daily_temperatures(values, count, result);
    i = 0;
    while (i < count) {
        putint(result[i]);
        putch(10);
        i = i + 1;
    }
    return 0;
}
