// Source: LeetCode 26. Remove Duplicates from Sorted Array
// Problem: https://leetcode.com/problems/remove-duplicates-from-sorted-array/
// Discuss reference: https://leetcode.com/discuss/post/2079840/remove-duplicates-from-sorted-array/
// Adapted for SysyCC runtime regression: read n and a sorted array, compact it
// in place, then print the new length followed by the retained elements.

int remove_duplicates(int values[16], int count) {
    int write_index = 0;
    int read_index = 0;

    if (count == 0) {
        return 0;
    }

    write_index = 1;
    read_index = 1;
    while (read_index < count) {
        if (values[read_index] != values[read_index - 1]) {
            values[write_index] = values[read_index];
            write_index = write_index + 1;
        }
        read_index = read_index + 1;
    }

    return write_index;
}

int main() {
    int values[16];
    int count = 0;
    int i = 0;
    int unique_count = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    unique_count = remove_duplicates(values, count);
    putint(unique_count);
    putch(10);

    i = 0;
    while (i < unique_count) {
        putint(values[i]);
        putch(10);
        i = i + 1;
    }

    return 0;
}
