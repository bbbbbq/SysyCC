// Source: LeetCode 215. Kth Largest Element in an Array
// Problem: https://leetcode.com/problems/kth-largest-element-in-an-array/
// Adapted for SysyCC runtime regression: read n, k, and values, then print the
// k-th largest value using an in-place max heap.

int heap_values[32];

void swap_heap(int lhs, int rhs) {
    int temp = heap_values[lhs];
    heap_values[lhs] = heap_values[rhs];
    heap_values[rhs] = temp;
}

void sift_down(int count, int index) {
    int child = 0;
    int best = 0;

    while (1) {
        child = index * 2 + 1;
        if (child >= count) {
            return;
        }
        best = child;
        if (child + 1 < count && heap_values[child + 1] > heap_values[child]) {
            best = child + 1;
        }
        if (heap_values[index] >= heap_values[best]) {
            return;
        }
        swap_heap(index, best);
        index = best;
    }
}

void build_heap(int count) {
    int index = count / 2 - 1;
    while (index >= 0) {
        sift_down(count, index);
        index = index - 1;
    }
}

int pop_heap(int *count) {
    int result = heap_values[0];
    *count = *count - 1;
    heap_values[0] = heap_values[*count];
    sift_down(*count, 0);
    return result;
}

int main() {
    int count = 0;
    int kth = 0;
    int heap_size = 0;
    int i = 0;

    count = getint();
    kth = getint();
    while (i < count) {
        heap_values[i] = getint();
        i = i + 1;
    }

    heap_size = count;
    build_heap(heap_size);

    i = 1;
    while (i < kth) {
        pop_heap(&heap_size);
        i = i + 1;
    }

    putint(heap_values[0]);
    putch(10);
    return 0;
}
