// Source: LeetCode 305. Number of Islands II
// Problem: https://leetcode.com/problems/number-of-islands-ii/
// Adapted for SysyCC runtime regression: read rows, cols, and land-add
// operations, then print the island count after each operation using
// union-find over a 2D grid.

int parent_set[64];
int rank_set[64];
int active_cell[64];

int find_root(int value) {
    while (parent_set[value] != value) {
        parent_set[value] = parent_set[parent_set[value]];
        value = parent_set[value];
    }
    return value;
}

int union_sets(int lhs, int rhs) {
    int left_root = find_root(lhs);
    int right_root = find_root(rhs);

    if (left_root == right_root) {
        return 0;
    }

    if (rank_set[left_root] < rank_set[right_root]) {
        parent_set[left_root] = right_root;
    } else {
        if (rank_set[left_root] > rank_set[right_root]) {
            parent_set[right_root] = left_root;
        } else {
            parent_set[right_root] = left_root;
            rank_set[left_root] = rank_set[left_root] + 1;
        }
    }
    return 1;
}

int main() {
    int rows = 0;
    int cols = 0;
    int operations = 0;
    int islands = 0;
    int row = 0;
    int col = 0;
    int index = 0;
    int neighbor = 0;
    int i = 0;

    rows = getint();
    cols = getint();
    operations = getint();

    i = 0;
    while (i < rows * cols) {
        parent_set[i] = i;
        rank_set[i] = 0;
        active_cell[i] = 0;
        i = i + 1;
    }

    i = 0;
    while (i < operations) {
        row = getint();
        col = getint();
        index = row * cols + col;

        if (!active_cell[index]) {
            active_cell[index] = 1;
            islands = islands + 1;

            if (row > 0) {
                neighbor = (row - 1) * cols + col;
                if (active_cell[neighbor]) {
                    islands = islands - union_sets(index, neighbor);
                }
            }
            if (row + 1 < rows) {
                neighbor = (row + 1) * cols + col;
                if (active_cell[neighbor]) {
                    islands = islands - union_sets(index, neighbor);
                }
            }
            if (col > 0) {
                neighbor = row * cols + col - 1;
                if (active_cell[neighbor]) {
                    islands = islands - union_sets(index, neighbor);
                }
            }
            if (col + 1 < cols) {
                neighbor = row * cols + col + 1;
                if (active_cell[neighbor]) {
                    islands = islands - union_sets(index, neighbor);
                }
            }
        }

        putint(islands);
        putch(10);
        i = i + 1;
    }

    return 0;
}
