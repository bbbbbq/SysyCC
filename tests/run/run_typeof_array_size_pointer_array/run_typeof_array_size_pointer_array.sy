typedef unsigned long size_t;

#define ARRAY_SIZE(x) \
    (sizeof(x) / sizeof((x)[0]) + \
     (sizeof(char[1 - 2 * !(!__builtin_types_compatible_p(__typeof__(x), __typeof__(&(x)[0])))]) - 1))

struct ObjectId {
    int oid;
};

struct Object {
    struct ObjectId oid;
};

struct Tree {
    struct Object object;
    int size;
};

static struct Tree g_tree;

static struct Tree *make_tree(const struct ObjectId *oid) {
    (void)oid;
    return &g_tree;
}

int main(void) {
    const struct ObjectId *oid[] = {0, 0};
    struct Tree *tree[ARRAY_SIZE(oid)];
    int sum = 0;

    g_tree.object.oid.oid = 7;
    g_tree.size = 5;

    for (size_t i = 0; i < ARRAY_SIZE(oid); i++) {
        tree[i] = make_tree(oid[i]);
        sum += tree[i]->object.oid.oid + tree[i]->size;
    }

    return sum == 24 ? 0 : sum;
}
