#pragma pack(push)
#pragma pack(1)
struct S1 {
    short f0;
    unsigned char f1;
    unsigned int f2;
    int f3;
};
#pragma pack(pop)

union U1 {
    struct S1 f0;
    unsigned long long f1;
};

static union U1 g_value = {{0x758E, 0x2E, 0xA8ED40A1U, 0x501874DA}};

int main(void) {
    putint(g_value.f0.f0);
    putch(10);
    putint((int)g_value.f0.f1);
    putch(10);
    putint((int)g_value.f0.f2);
    putch(10);
    putint(g_value.f0.f3);
    putch(10);
    return 0;
}
