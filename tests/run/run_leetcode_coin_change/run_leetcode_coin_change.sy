// Source: LeetCode 322. Coin Change
// Problem: https://leetcode.com/problems/coin-change/
// Adapted for SysyCC runtime regression: read coin count, coins, and target,
// then print the minimum number of coins or -1.

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int dp_values[128];
int coin_values[16];

int main() {
    int coin_count = 0;
    int amount = 0;
    int i = 0;
    int current = 0;

    coin_count = getint();
    while (i < coin_count) {
        coin_values[i] = getint();
        i = i + 1;
    }
    amount = getint();

    dp_values[0] = 0;
    current = 1;
    while (current <= amount) {
        dp_values[current] = 1000000;
        i = 0;
        while (i < coin_count) {
            if (coin_values[i] <= current &&
                dp_values[current - coin_values[i]] + 1 < dp_values[current]) {
                dp_values[current] = dp_values[current - coin_values[i]] + 1;
            }
            i = i + 1;
        }
        current = current + 1;
    }

    if (dp_values[amount] >= 1000000) {
        putint(-1);
    } else {
        putint(dp_values[amount]);
    }
    putch(10);
    return 0;
}
