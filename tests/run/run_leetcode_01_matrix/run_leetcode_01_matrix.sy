// Source: LeetCode 542. 01 Matrix
// Problem: https://leetcode.com/problems/01-matrix/
// Adapted for SysyCC runtime regression: read rows, cols, and a 0/1 matrix,
// then print distance-to-zero for every cell using multi-source BFS.

int input_grid[8][8];
int distance_grid[8][8];
int row_queue[64];
int col_queue[64];

int main() {
    int rows = 0;
    int cols = 0;
    int head = 0;
    int tail = 0;
    int row = 0;
    int col = 0;
    int nr = 0;
    int nc = 0;
    int i = 0;
    int j = 0;

    rows = getint();
    cols = getint();

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            input_grid[i][j] = getint();
            if (input_grid[i][j] == 0) {
                distance_grid[i][j] = 0;
                row_queue[tail] = i;
                col_queue[tail] = j;
                tail = tail + 1;
            } else {
                distance_grid[i][j] = -1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    while (head < tail) {
        row = row_queue[head];
        col = col_queue[head];
        head = head + 1;

        nr = row + 1;
        nc = col;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols &&
            distance_grid[nr][nc] == -1) {
            distance_grid[nr][nc] = distance_grid[row][col] + 1;
            row_queue[tail] = nr;
            col_queue[tail] = nc;
            tail = tail + 1;
        }

        nr = row - 1;
        nc = col;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols &&
            distance_grid[nr][nc] == -1) {
            distance_grid[nr][nc] = distance_grid[row][col] + 1;
            row_queue[tail] = nr;
            col_queue[tail] = nc;
            tail = tail + 1;
        }

        nr = row;
        nc = col + 1;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols &&
            distance_grid[nr][nc] == -1) {
            distance_grid[nr][nc] = distance_grid[row][col] + 1;
            row_queue[tail] = nr;
            col_queue[tail] = nc;
            tail = tail + 1;
        }

        nr = row;
        nc = col - 1;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols &&
            distance_grid[nr][nc] == -1) {
            distance_grid[nr][nc] = distance_grid[row][col] + 1;
            row_queue[tail] = nr;
            col_queue[tail] = nc;
            tail = tail + 1;
        }
    }

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            putint(distance_grid[i][j]);
            putch(10);
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}
