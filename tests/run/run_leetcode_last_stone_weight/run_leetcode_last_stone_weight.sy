// Source: LeetCode 1046. Last Stone Weight
// Problem: https://leetcode.com/problems/last-stone-weight/
// Adapted for SysyCC runtime regression: read n and stone weights, then print
// the final remaining weight using a max heap simulation.

int heap_values[32];

void swap_heap(int lhs, int rhs) {
    int temp = heap_values[lhs];
    heap_values[lhs] = heap_values[rhs];
    heap_values[rhs] = temp;
}

void sift_up(int index) {
    int parent = 0;
    while (index > 0) {
        parent = (index - 1) / 2;
        if (heap_values[parent] >= heap_values[index]) {
            return;
        }
        swap_heap(parent, index);
        index = parent;
    }
}

void sift_down(int count, int index) {
    int child = 0;
    int best = 0;
    while (1) {
        child = index * 2 + 1;
        if (child >= count) {
            return;
        }
        best = child;
        if (child + 1 < count && heap_values[child + 1] > heap_values[child]) {
            best = child + 1;
        }
        if (heap_values[index] >= heap_values[best]) {
            return;
        }
        swap_heap(index, best);
        index = best;
    }
}

void build_heap(int count) {
    int index = count / 2 - 1;
    while (index >= 0) {
        sift_down(count, index);
        index = index - 1;
    }
}

int pop_heap(int *count) {
    int result = heap_values[0];
    *count = *count - 1;
    heap_values[0] = heap_values[*count];
    sift_down(*count, 0);
    return result;
}

void push_heap(int *count, int value) {
    heap_values[*count] = value;
    *count = *count + 1;
    sift_up(*count - 1);
}

int main() {
    int count = 0;
    int heap_size = 0;
    int i = 0;
    int first = 0;
    int second = 0;

    count = getint();
    while (i < count) {
        heap_values[i] = getint();
        i = i + 1;
    }

    heap_size = count;
    build_heap(heap_size);
    while (heap_size > 1) {
        first = pop_heap(&heap_size);
        second = pop_heap(&heap_size);
        if (first != second) {
            push_heap(&heap_size, first - second);
        }
    }

    if (heap_size == 0) {
        putint(0);
    } else {
        putint(heap_values[0]);
    }
    putch(10);
    return 0;
}
