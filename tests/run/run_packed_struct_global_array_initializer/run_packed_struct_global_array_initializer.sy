typedef int (*handler_t)(int);

int add_three(int value) {
    return value + 3;
}

int sub_one(int value) {
    return value - 1;
}

static const struct {
    handler_t handler;
    unsigned max_length : 12;
    unsigned min_length : 8;
    unsigned before : 4;
    unsigned after : 4;
    unsigned multiple : 1;
} read_chunks[2] = {
    {add_three, 0x123U, 4U, 5U, 6U, 1U},
    {sub_one, 0x456U, 7U, 8U, 9U, 0U},
};

int main(void) {
    if (read_chunks[0].handler(39) != 42) {
        return 1;
    }
    if (read_chunks[1].handler(43) != 42) {
        return 2;
    }
    if (read_chunks[0].max_length != 0x123U ||
        read_chunks[0].min_length != 4U ||
        read_chunks[0].before != 5U ||
        read_chunks[0].after != 6U ||
        read_chunks[0].multiple != 1U) {
        return 3;
    }
    if (read_chunks[1].max_length != 0x456U ||
        read_chunks[1].min_length != 7U ||
        read_chunks[1].before != 8U ||
        read_chunks[1].after != 9U ||
        read_chunks[1].multiple != 0U) {
        return 4;
    }
    return 0;
}
