enum Value {
    PRIMARY = (1 ? 4 : 2)
};

int main(void) {
    int values[(1 > 0) ? 3 : 1];
    int result = 0;
    values[2] = PRIMARY;

    switch (PRIMARY) {
    case (1 ? 4 : 0): {
        result = values[2];
        break;
    }
    default: {
        result = 0;
        break;
    }
    }
    putint(result);
    putch(10);
    return result == PRIMARY ? 0 : 1;
}
