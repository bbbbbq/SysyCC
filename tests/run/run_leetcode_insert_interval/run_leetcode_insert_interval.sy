// Source: LeetCode 57. Insert Interval
// Problem: https://leetcode.com/problems/insert-interval/
// Adapted for SysyCC runtime regression: read n sorted non-overlapping
// intervals, then one new interval, insert and merge, and print the result.

int starts[32];
int ends[32];

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int main() {
    int count = 0;
    int new_start = 0;
    int new_end = 0;
    int out_starts[32];
    int out_ends[32];
    int out_count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        starts[i] = getint();
        ends[i] = getint();
        i = i + 1;
    }
    new_start = getint();
    new_end = getint();

    i = 0;
    while (i < count && ends[i] < new_start) {
        out_starts[out_count] = starts[i];
        out_ends[out_count] = ends[i];
        out_count = out_count + 1;
        i = i + 1;
    }

    while (i < count && starts[i] <= new_end) {
        new_start = min_int(new_start, starts[i]);
        new_end = max_int(new_end, ends[i]);
        i = i + 1;
    }

    out_starts[out_count] = new_start;
    out_ends[out_count] = new_end;
    out_count = out_count + 1;

    while (i < count) {
        out_starts[out_count] = starts[i];
        out_ends[out_count] = ends[i];
        out_count = out_count + 1;
        i = i + 1;
    }

    i = 0;
    while (i < out_count) {
        putint(out_starts[i]);
        putch(10);
        putint(out_ends[i]);
        putch(10);
        i = i + 1;
    }
    return 0;
}
