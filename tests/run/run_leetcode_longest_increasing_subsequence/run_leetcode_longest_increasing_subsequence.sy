// Source: LeetCode 300. Longest Increasing Subsequence
// Problem: https://leetcode.com/problems/longest-increasing-subsequence/
// Adapted for SysyCC runtime regression: read n and values, then print the
// LIS length using O(n^2) dynamic programming.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int lis_length(int values[32], int count) {
    int dp[32];
    int best = 0;
    int i = 0;
    int j = 0;

    while (i < count) {
        dp[i] = 1;
        j = 0;
        while (j < i) {
            if (values[j] < values[i]) {
                dp[i] = max_int(dp[i], dp[j] + 1);
            }
            j = j + 1;
        }
        best = max_int(best, dp[i]);
        i = i + 1;
    }

    return best;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(lis_length(values, count));
    putch(10);
    return 0;
}
