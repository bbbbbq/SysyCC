typedef struct Desc_s Desc;

struct Pair {
    int value;
};

struct Desc_s {
    const struct Pair *items;
    int count;
};

static const struct Pair pairs[2] = {{7}, {11}};
static const Desc desc = {pairs, 2};

int main() {
    if (desc.count != 2) {
        return 1;
    }
    if (desc.items[0].value != 7) {
        return 2;
    }
    if (desc.items[1].value != 11) {
        return 3;
    }
    return 0;
}
