// Source: LeetCode 452. Minimum Number of Arrows to Burst Balloons
// Problem: https://leetcode.com/problems/minimum-number-of-arrows-to-burst-balloons/
// Adapted for SysyCC runtime regression: read n intervals, greedily choose end
// points, and print the minimum arrows needed.

int start_values[32];
int end_values[32];

void swap_value(int values[32], int lhs, int rhs) {
    int temp = values[lhs];
    values[lhs] = values[rhs];
    values[rhs] = temp;
}

void sort_by_end(int count) {
    int i = 0;
    int j = 0;
    i = 0;
    while (i < count) {
        j = i + 1;
        while (j < count) {
            if (end_values[j] < end_values[i]) {
                swap_value(start_values, i, j);
                swap_value(end_values, i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

int main() {
    int count = 0;
    int i = 0;
    int arrows = 1;
    int current_end = 0;

    count = getint();
    while (i < count) {
        start_values[i] = getint();
        end_values[i] = getint();
        i = i + 1;
    }

    sort_by_end(count);
    current_end = end_values[0];

    i = 1;
    while (i < count) {
        if (start_values[i] > current_end) {
            arrows = arrows + 1;
            current_end = end_values[i];
        }
        i = i + 1;
    }

    putint(arrows);
    putch(10);
    return 0;
}
