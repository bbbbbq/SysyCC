// Source: LeetCode 152. Maximum Product Subarray
// Problem: https://leetcode.com/problems/maximum-product-subarray/
// Adapted for SysyCC runtime regression: read n and values, then print the
// maximum contiguous product.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int max_product(int values[32], int count) {
    int current_max = values[0];
    int current_min = values[0];
    int best = values[0];
    int i = 1;
    int candidate_a = 0;
    int candidate_b = 0;
    int candidate_c = 0;

    while (i < count) {
        candidate_a = values[i];
        candidate_b = current_max * values[i];
        candidate_c = current_min * values[i];

        current_max = max_int(candidate_a, max_int(candidate_b, candidate_c));
        current_min = min_int(candidate_a, min_int(candidate_b, candidate_c));
        best = max_int(best, current_max);
        i = i + 1;
    }

    return best;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(max_product(values, count));
    putch(10);
    return 0;
}
