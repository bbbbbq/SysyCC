// Source: LeetCode 238. Product of Array Except Self
// Problem: https://leetcode.com/problems/product-of-array-except-self/
// Adapted for SysyCC runtime regression: read n and an array, then print the
// product-except-self result per line using prefix/suffix products.

void product_except_self(int values[32], int count, int result[32]) {
    int prefix = 1;
    int suffix = 1;
    int i = 0;

    while (i < count) {
        result[i] = prefix;
        prefix = prefix * values[i];
        i = i + 1;
    }

    i = count - 1;
    while (i >= 0) {
        result[i] = result[i] * suffix;
        suffix = suffix * values[i];
        i = i - 1;
    }
}

int main() {
    int values[32];
    int result[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    product_except_self(values, count, result);
    i = 0;
    while (i < count) {
        putint(result[i]);
        putch(10);
        i = i + 1;
    }
    return 0;
}
