// Source: LeetCode 128. Longest Consecutive Sequence
// Problem: https://leetcode.com/problems/longest-consecutive-sequence/
// Adapted for SysyCC runtime regression: read n and values, sort them, then
// print the longest consecutive run length.

int values[32];

void swap_values(int lhs, int rhs) {
    int temp = values[lhs];
    values[lhs] = values[rhs];
    values[rhs] = temp;
}

void sort_values(int count) {
    int i = 0;
    int j = 0;

    i = 0;
    while (i < count) {
        j = i + 1;
        while (j < count) {
            if (values[j] < values[i]) {
                swap_values(i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int main() {
    int count = 0;
    int best = 1;
    int current = 1;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    sort_values(count);

    i = 1;
    while (i < count) {
        if (values[i] == values[i - 1]) {
            i = i + 1;
            continue;
        }
        if (values[i] == values[i - 1] + 1) {
            current = current + 1;
            best = max_int(best, current);
        } else {
            current = 1;
        }
        i = i + 1;
    }

    putint(best);
    putch(10);
    return 0;
}
