// Source: LeetCode 48. Rotate Image
// Problem: https://leetcode.com/problems/rotate-image/
// Adapted for SysyCC runtime regression: read n and an n x n matrix, rotate it
// 90 degrees clockwise in place, then print the result.

int main() {
    int matrix[6][6];
    int size = 0;
    int i = 0;
    int j = 0;
    int temp = 0;

    size = getint();

    i = 0;
    while (i < size) {
        j = 0;
        while (j < size) {
            matrix[i][j] = getint();
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < size) {
        j = i + 1;
        while (j < size) {
            temp = matrix[i][j];
            matrix[i][j] = matrix[j][i];
            matrix[j][i] = temp;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < size) {
        j = 0;
        while (j < size / 2) {
            temp = matrix[i][j];
            matrix[i][j] = matrix[i][size - 1 - j];
            matrix[i][size - 1 - j] = temp;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < size) {
        j = 0;
        while (j < size) {
            putint(matrix[i][j]);
            putch(10);
            j = j + 1;
        }
        i = i + 1;
    }

    return 0;
}
