int main(void) {
    void *pointer_value = (void*)0x12345;
    long long raw_value = (long long)pointer_value;
    int truncated = (int)3.9;
    float widened = (float)9223372036854775807LL;

    putint(raw_value != 0);
    putch(10);
    putint(truncated);
    putch(10);
    putint(widened > 0.0f);
    putch(10);
    return 0;
}
