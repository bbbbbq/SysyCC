// Source: LeetCode 121. Best Time to Buy and Sell Stock
// Problem: https://leetcode.com/problems/best-time-to-buy-and-sell-stock/
// Discuss reference: https://leetcode.com/discuss/post/4351329/stock-profit-maximization-made-simple-best-time-to-buy-and-sell-stocks/
// Adapted for SysyCC runtime regression: read n daily prices and print the
// best single-transaction profit.

int max_profit_once(int prices[16], int count) {
    int best_profit = 0;
    int min_price = prices[0];
    int i = 1;
    int candidate = 0;

    while (i < count) {
        if (prices[i] < min_price) {
            min_price = prices[i];
        } else {
            candidate = prices[i] - min_price;
            if (candidate > best_profit) {
                best_profit = candidate;
            }
        }
        i = i + 1;
    }

    return best_profit;
}

int main() {
    int prices[16];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        prices[i] = getint();
        i = i + 1;
    }

    putint(max_profit_once(prices, count));
    putch(10);
    return 0;
}
