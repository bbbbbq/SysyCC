union PayloadWord {
    int word;
    char bytes[4];
};

int g_nums[2] = {1, 2};

struct Pair {
    int left;
    int right;
};

struct Payload {
    struct Pair nums;
    union PayloadWord word;
};

struct Payload g_payload = {{4, 5}, {6}};

int main(void) {
    int l_nums[2] = {1, 2};
    struct Payload l_payload = {{4, 5}, {6}};

    if (g_nums[0] != l_nums[0]) {
        return 1;
    }
    if (g_nums[1] != l_nums[1]) {
        return 2;
    }
    if (g_payload.nums.left != l_payload.nums.left) {
        return 3;
    }
    if (g_payload.nums.right != l_payload.nums.right) {
        return 4;
    }
    if (g_payload.word.word != l_payload.word.word) {
        return 5;
    }

    return 0;
}
