void putint(int value);
void putch(int value);

int ptrs[4];
int idxs[6];
int vals[6];
int a[3];
int b[3];

void accumulate(int n, int ptrs[], int idxs[], int vals[], int scale[], int out[]) {
    int i;
    int j;

    i = 0;
    while (i < n) {
        out[i] = 0;
        i = i + 1;
    }

    i = 0;
    while (i < n) {
        j = ptrs[i];
        while (j < ptrs[i + 1]) {
            out[idxs[j]] = out[idxs[j]] + vals[j];
            j = j + 1;
        }
        j = ptrs[i];
        while (j < ptrs[i + 1]) {
            out[idxs[j]] = out[idxs[j]] + vals[j] * (scale[i] - 1);
            j = j + 1;
        }
        i = i + 1;
    }
}

int main() {
    int n = 3;
    int k = 0;

    ptrs[0] = 0;
    ptrs[1] = 2;
    ptrs[2] = 4;
    ptrs[3] = 6;

    idxs[0] = 0;
    idxs[1] = 1;
    idxs[2] = 1;
    idxs[3] = 2;
    idxs[4] = 2;
    idxs[5] = 0;

    vals[0] = 1;
    vals[1] = 2;
    vals[2] = 3;
    vals[3] = 4;
    vals[4] = 5;
    vals[5] = 6;

    a[0] = 2;
    a[1] = 3;
    a[2] = 4;

    while (k < 3) {
        accumulate(n, ptrs, idxs, vals, a, b);
        accumulate(n, ptrs, idxs, vals, b, a);
        k = k + 1;
    }

    putint(b[0]);
    putch(10);
    putint(b[1]);
    putch(10);
    putint(b[2]);
    putch(10);
    return 0;
}
