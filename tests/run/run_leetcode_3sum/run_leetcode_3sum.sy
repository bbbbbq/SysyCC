// Source: LeetCode 15. 3Sum
// Problem: https://leetcode.com/problems/3sum/
// Adapted for SysyCC runtime regression: read n and values, then print all
// unique zero-sum triplets after sorting, one number per line.

int values[32];

void swap_values(int lhs, int rhs) {
    int temp = values[lhs];
    values[lhs] = values[rhs];
    values[rhs] = temp;
}

void sort_values(int count) {
    int i = 0;
    int j = 0;

    i = 0;
    while (i < count) {
        j = i + 1;
        while (j < count) {
            if (values[j] < values[i]) {
                swap_values(i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

int main() {
    int count = 0;
    int i = 0;
    int left = 0;
    int right = 0;
    int sum = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    sort_values(count);

    i = 0;
    while (i < count - 2) {
        if (i == 0 || values[i] != values[i - 1]) {
            left = i + 1;
            right = count - 1;
            while (left < right) {
                sum = values[i] + values[left] + values[right];
                if (sum == 0) {
                    putint(values[i]);
                    putch(10);
                    putint(values[left]);
                    putch(10);
                    putint(values[right]);
                    putch(10);
                    left = left + 1;
                    right = right - 1;
                    while (left < right && values[left] == values[left - 1]) {
                        left = left + 1;
                    }
                    while (left < right && values[right] == values[right + 1]) {
                        right = right - 1;
                    }
                } else {
                    if (sum < 0) {
                        left = left + 1;
                    } else {
                        right = right - 1;
                    }
                }
            }
        }
        i = i + 1;
    }

    return 0;
}
