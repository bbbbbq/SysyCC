int sum_with_prefetch(int *values, int count) {
    int total = 0;
    for (int i = 0; i < count; i = i + 1) {
        __builtin_prefetch(values + i);
        __builtin_prefetch(values + i, 0, 2);
        total = total + values[i];
    }
    return total;
}

int main(void) {
    int values[4] = {1, 2, 3, 4};
    return sum_with_prefetch(values, 4) == 10 ? 0 : 1;
}
