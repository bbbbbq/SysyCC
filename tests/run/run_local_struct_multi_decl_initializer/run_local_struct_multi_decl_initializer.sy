struct Mapping {
    int destination_start, destination_length, source_start, source_length;
};

int main(void) {
    int start_a = 1;
    int length_a = 2;
    int start_b = 3;
    int length_b = 4;
    struct Mapping mapping = {start_a, length_a, start_b, length_b};
    return mapping.destination_start + mapping.destination_length * 10 +
           mapping.source_start * 100 + mapping.source_length * 1000;
}
