int fill_and_sum(int n) {
    unsigned char values[n];
    int sum = 0;
    for (int i = 0; i < n; i = i + 1) {
        values[i] = (unsigned char)(i + 1);
    }
    for (int i = 0; i < n; i = i + 1) {
        sum = sum + values[i];
    }
    return sum;
}

int main(void) {
    return fill_and_sum(5) == 15 ? 0 : 1;
}
