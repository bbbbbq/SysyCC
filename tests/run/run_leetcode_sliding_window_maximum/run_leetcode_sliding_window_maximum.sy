// Source: LeetCode 239. Sliding Window Maximum
// Problem: https://leetcode.com/problems/sliding-window-maximum/
// Adapted for SysyCC runtime regression: read n, k, and values, then print
// each window maximum using a monotonic deque of indices.

void window_maximums(int values[32], int count, int window_size, int result[32]) {
    int deque_indices[32];
    int front = 0;
    int back = 0;
    int result_index = 0;
    int i = 0;

    while (i < count) {
        while (front < back && deque_indices[front] <= i - window_size) {
            front = front + 1;
        }
        while (front < back && values[deque_indices[back - 1]] <= values[i]) {
            back = back - 1;
        }
        deque_indices[back] = i;
        back = back + 1;

        if (i >= window_size - 1) {
            result[result_index] = values[deque_indices[front]];
            result_index = result_index + 1;
        }
        i = i + 1;
    }
}

int main() {
    int values[32];
    int result[32];
    int count = 0;
    int window_size = 0;
    int i = 0;

    count = getint();
    window_size = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    window_maximums(values, count, window_size, result);
    i = 0;
    while (i <= count - window_size) {
        putint(result[i]);
        putch(10);
        i = i + 1;
    }
    return 0;
}
