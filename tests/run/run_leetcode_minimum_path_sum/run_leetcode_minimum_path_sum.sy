// Source: LeetCode 64. Minimum Path Sum
// Problem: https://leetcode.com/problems/minimum-path-sum/
// Adapted for SysyCC runtime regression: read rows, cols, and a grid, then
// print the minimum sum path from top-left to bottom-right.

int grid_values[8][8];
int dp_values[8][8];

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int main() {
    int rows = 0;
    int cols = 0;
    int i = 0;
    int j = 0;

    rows = getint();
    cols = getint();

    i = 0;
    while (i < rows) {
        j = 0;
        while (j < cols) {
            grid_values[i][j] = getint();
            dp_values[i][j] = 0;
            j = j + 1;
        }
        i = i + 1;
    }

    dp_values[0][0] = grid_values[0][0];
    i = 1;
    while (i < rows) {
        dp_values[i][0] = dp_values[i - 1][0] + grid_values[i][0];
        i = i + 1;
    }
    j = 1;
    while (j < cols) {
        dp_values[0][j] = dp_values[0][j - 1] + grid_values[0][j];
        j = j + 1;
    }

    i = 1;
    while (i < rows) {
        j = 1;
        while (j < cols) {
            dp_values[i][j] = min_int(dp_values[i - 1][j], dp_values[i][j - 1]) +
                              grid_values[i][j];
            j = j + 1;
        }
        i = i + 1;
    }

    putint(dp_values[rows - 1][cols - 1]);
    putch(10);
    return 0;
}
