// Source: LeetCode 45. Jump Game II
// Problem: https://leetcode.com/problems/jump-game-ii/
// Adapted for SysyCC runtime regression: read n and jump lengths, then print
// the minimum jump count using greedy layer expansion.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int jump_count(int values[32], int count) {
    int jumps = 0;
    int current_end = 0;
    int farthest = 0;
    int i = 0;

    if (count <= 1) {
        return 0;
    }

    while (i < count - 1) {
        farthest = max_int(farthest, i + values[i]);
        if (i == current_end) {
            jumps = jumps + 1;
            current_end = farthest;
        }
        i = i + 1;
    }

    return jumps;
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(jump_count(values, count));
    putch(10);
    return 0;
}
