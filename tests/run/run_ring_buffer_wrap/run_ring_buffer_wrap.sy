int main() {
    int slot0 = 0;
    int slot1 = 0;
    int slot2 = 0;
    int head = 0;
    int tail = 0;
    int count = 0;

    slot0 = getint();
    tail = 1;
    count = 1;

    slot1 = getint();
    tail = 2;
    count = 2;

    slot2 = getint();
    tail = 0;
    count = 3;

    if (head == 0) {
        putint(slot0);
        putch(10);
    }
    head = 1;
    count = 2;

    if (tail == 0) {
        slot0 = getint();
        tail = 1;
        count = 3;
    }

    while (count > 0) {
        if (head == 0) {
            putint(slot0);
            head = 1;
        } else {
            if (head == 1) {
                putint(slot1);
                head = 2;
            } else {
                putint(slot2);
                head = 0;
            }
        }
        putch(10);
        count = count - 1;
    }

    return 0;
}
