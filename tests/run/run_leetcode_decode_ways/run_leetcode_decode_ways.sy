// Source: LeetCode 91. Decode Ways
// Problem: https://leetcode.com/problems/decode-ways/
// Adapted for SysyCC runtime regression: read digit count and digits as ints,
// then print the number of valid decodings.

int digits[32];
int dp_values[33];

int main() {
    int count = 0;
    int i = 0;
    int pair_value = 0;

    count = getint();
    while (i < count) {
        digits[i] = getint();
        i = i + 1;
    }

    dp_values[0] = 1;
    if (digits[0] == 0) {
        putint(0);
        putch(10);
        return 0;
    }
    dp_values[1] = 1;

    i = 2;
    while (i <= count) {
        dp_values[i] = 0;
        if (digits[i - 1] != 0) {
            dp_values[i] = dp_values[i] + dp_values[i - 1];
        }
        pair_value = digits[i - 2] * 10 + digits[i - 1];
        if (pair_value >= 10 && pair_value <= 26) {
            dp_values[i] = dp_values[i] + dp_values[i - 2];
        }
        i = i + 1;
    }

    putint(dp_values[count]);
    putch(10);
    return 0;
}
