// Source: LeetCode 42. Trapping Rain Water
// Problem: https://leetcode.com/problems/trapping-rain-water/
// Adapted for SysyCC runtime regression: read n and heights, then print the
// trapped water volume using prefix/suffix maxima.

int min_int(int lhs, int rhs) {
    if (lhs < rhs) {
        return lhs;
    }
    return rhs;
}

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int trap(int heights[32], int count) {
    int left_max[32];
    int right_max[32];
    int i = 0;
    int water = 0;

    if (count <= 0) {
        return 0;
    }

    left_max[0] = heights[0];
    i = 1;
    while (i < count) {
        left_max[i] = max_int(left_max[i - 1], heights[i]);
        i = i + 1;
    }

    right_max[count - 1] = heights[count - 1];
    i = count - 2;
    while (i >= 0) {
        right_max[i] = max_int(right_max[i + 1], heights[i]);
        i = i - 1;
    }

    i = 0;
    while (i < count) {
        water = water + min_int(left_max[i], right_max[i]) - heights[i];
        i = i + 1;
    }

    return water;
}

int main() {
    int heights[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        heights[i] = getint();
        i = i + 1;
    }

    putint(trap(heights, count));
    putch(10);
    return 0;
}
