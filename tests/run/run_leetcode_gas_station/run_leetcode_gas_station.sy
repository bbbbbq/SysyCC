// Source: LeetCode 134. Gas Station
// Problem: https://leetcode.com/problems/gas-station/
// Adapted for SysyCC runtime regression: read n, gas array, and cost array,
// then print the valid starting station index or -1.

int can_complete(int gas[32], int cost[32], int count) {
    int total = 0;
    int tank = 0;
    int start = 0;
    int i = 0;
    int delta = 0;

    while (i < count) {
        delta = gas[i] - cost[i];
        total = total + delta;
        tank = tank + delta;
        if (tank < 0) {
            tank = 0;
            start = i + 1;
        }
        i = i + 1;
    }

    if (total < 0) {
        return -1;
    }
    return start;
}

int main() {
    int gas[32];
    int cost[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        gas[i] = getint();
        i = i + 1;
    }

    i = 0;
    while (i < count) {
        cost[i] = getint();
        i = i + 1;
    }

    putint(can_complete(gas, cost, count));
    putch(10);
    return 0;
}
