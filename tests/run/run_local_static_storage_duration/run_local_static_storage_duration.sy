struct Entry {
    const char *name;
    void *tag;
    struct Entry *next;
};

struct Entry *get_entries(void) {
    static struct Entry entries[2] = {
        {"alpha", (void*)1, 0},
        {"beta", (void*)2, 0},
    };
    entries[0].next = &entries[1];
    return entries;
}

int clobber_stack(void) {
    char scratch[512];
    int i = 0;
    while (i < 512) {
        scratch[i] = (char)i;
        i = i + 1;
    }
    return scratch[7];
}

int main(void) {
    struct Entry *entries = get_entries();
    clobber_stack();
    if (entries[0].name[0] != 'a') {
        return 1;
    }
    if (entries[0].next == 0 || entries[0].next->name[0] != 'b') {
        return 2;
    }
    return 0;
}
