// Source: LeetCode 213. House Robber II
// Problem: https://leetcode.com/problems/house-robber-ii/
// Adapted for SysyCC runtime regression: read n and circular house values,
// then print the best robbery sum.

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int rob_range(int values[32], int start, int end) {
    int prev_two = 0;
    int prev_one = 0;
    int next_value = 0;
    int i = start;

    while (i <= end) {
        next_value = max_int(prev_one, prev_two + values[i]);
        prev_two = prev_one;
        prev_one = next_value;
        i = i + 1;
    }

    return prev_one;
}

int rob_circle(int values[32], int count) {
    if (count == 1) {
        return values[0];
    }
    return max_int(rob_range(values, 0, count - 2),
                   rob_range(values, 1, count - 1));
}

int main() {
    int values[32];
    int count = 0;
    int i = 0;

    count = getint();
    while (i < count) {
        values[i] = getint();
        i = i + 1;
    }

    putint(rob_circle(values, count));
    putch(10);
    return 0;
}
