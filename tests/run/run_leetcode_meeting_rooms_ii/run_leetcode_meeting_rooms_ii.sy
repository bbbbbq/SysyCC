// Source: LeetCode 253. Meeting Rooms II
// Problem: https://leetcode.com/problems/meeting-rooms-ii/
// Adapted for SysyCC runtime regression: read n intervals, then print the
// minimum number of concurrent meeting rooms.

int start_values[32];
int end_values[32];

void swap_value(int values[32], int lhs, int rhs) {
    int temp = values[lhs];
    values[lhs] = values[rhs];
    values[rhs] = temp;
}

void sort_values(int values[32], int count) {
    int i = 0;
    int j = 0;
    i = 0;
    while (i < count) {
        j = i + 1;
        while (j < count) {
            if (values[j] < values[i]) {
                swap_value(values, i, j);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

int max_int(int lhs, int rhs) {
    if (lhs > rhs) {
        return lhs;
    }
    return rhs;
}

int main() {
    int count = 0;
    int i = 0;
    int start_index = 0;
    int end_index = 0;
    int in_use = 0;
    int best = 0;

    count = getint();
    while (i < count) {
        start_values[i] = getint();
        end_values[i] = getint();
        i = i + 1;
    }

    sort_values(start_values, count);
    sort_values(end_values, count);

    while (start_index < count) {
        if (start_values[start_index] < end_values[end_index]) {
            in_use = in_use + 1;
            best = max_int(best, in_use);
            start_index = start_index + 1;
        } else {
            in_use = in_use - 1;
            end_index = end_index + 1;
        }
    }

    putint(best);
    putch(10);
    return 0;
}
